# --- Backend Python ---
backend/venv/
backend/.venv/
backend/.env
backend/.env.local
backend/.env.production
backend/__pycache__/
backend/**/*.py[cod]
backend/**/*.egg-info/
backend/dist/
backend/build/
backend/uploads/

# --- Frontend Node.js ---
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production

# --- Desktop (Electron) — packaging exploratoire, pas encore partagé ---
electron/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Base de données locale ---
*.db
*.sqlite
*.sqlite3

# --- Fichiers temporaires ---
*.tmp
*.temp
*.cache

# --- Fichiers uploadés (sauf référence) ---
*.csv
*.xlsx
