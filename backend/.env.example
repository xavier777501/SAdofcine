
<file path="backend/.env.example">
# ============================================
# SAD OFFICINE — Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

--- APPLICATION ---
APP_NAME=SAD Officine
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_ME_WITH_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
--- BASE DE DONNÉES ---
Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sad_officine_dev
--- CORS (Frontend React) ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
--- FICHIERS UPLOAD ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads
--- CALCUL SAD (valeurs par défaut métier) ---
DEFAULT_ORDER_COST=2500
DEFAULT_HOLDING_RATE=0.20
DEFAULT_CYCLE_DAYS=10
--- NIVEAUX DE SERVICE VED (facteurs Z par défaut) ---
Z_VITAL=2.326
Z_ESSENTIEL=1.645
Z_DESIRABLE=1.282
Z_NON_RENSEIGNE=1.645
